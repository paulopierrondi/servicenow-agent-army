{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "noEmit": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*.ts"]
}
