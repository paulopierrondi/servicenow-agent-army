# NextAuth (optional). Without GITHUB_ID + GITHUB_SECRET the Sign-in
# button is hidden and the app stays fully usable in anonymous mode.
GITHUB_ID=
GITHUB_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Telemetry (auto-detected on Vercel; set to false to opt out locally).
NEXT_PUBLIC_VERCEL_ANALYTICS=true
